{
    "manifest_version": 3,
    "name": "Gmail AI Reply Generator",
    "version": "1.0",
    "description": "Generate AI replies inside Gmail",
    "permissions": [
        "activeTab",
        "storage"
    ],
    "host_permissions": [
        "http://localhost:9090/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://mail.google.com/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}